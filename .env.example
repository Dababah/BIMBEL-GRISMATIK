# =========================================================
# KONFIGURASI ENVIRONMENT - BIMBEL GRISMATIK
# =========================================================
# Salin file ini menjadi ".env" lalu isi sesuai data Anda.
#   cp .env.example .env
# =========================================================

# Connection string database Neon (Postgres)
# Dapatkan dari dashboard Neon -> Connection Details -> "Pooled connection"
# Contoh:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL=""

# Koneksi langsung (non-pooled) - dibutuhkan untuk migrasi (prisma db push)
# Biasanya sama seperti di atas tapi tanpa "-pooler"
# Contoh:
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED=""

# NextAuth - kunci rahasia untuk session admin.
# Generate dengan menjalankan: openssl rand -base64 32
NEXTAUTH_SECRET=""

# URL aplikasi (saat lokal biarkan default, saat di Vercel ganti ke domain Anda)
NEXTAUTH_URL="http://localhost:3000"

# Akun Super Admin default yang akan dibuat oleh "npm run db:seed"
ADMIN_NAME="Admin Grismatik"
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@grismatik.com"
ADMIN_PASSWORD="admin123"
